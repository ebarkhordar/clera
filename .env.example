# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# --- Telegram ---
# For the MVP skeleton you can run with a single ordinary bot token from @BotFather.
# In production this token comes from getManagedBotToken per user (managed-bots mode).
TELEGRAM_BOT_TOKEN=123456:PLACEHOLDER_TOKEN_FROM_BOTFATHER

# Your own Telegram numeric user id — where draft approvals are sent (the "control chat").
# Message @userinfobot to find yours. Leave blank to fall back to the business owner's chat.
CONTROL_CHAT_ID=

# --- LLM providers ---
# "auto" (default): use ANTHROPIC_API_KEY if set, else the local `claude` CLI if
# installed, else a placeholder draft. Force a backend with "anthropic" or "cli".
LLM_PROVIDER=auto
# Path to the Claude CLI (used when LLM_PROVIDER=cli or auto with no API key).
CLAUDE_CLI_PATH=claude
# Only needed for the API backend; leave blank to use the CLI or placeholder.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=              # reserved for the second provider

# --- Model tiers (override defaults if you like) ---
MODEL_BEST=claude-opus-4-8
MODEL_FAST=claude-haiku-4-5-20251001
DEFAULT_TIER=fast              # "best" or "fast"

# --- Storage ---
# "sqlite" (persists to SQLITE_PATH) or "memory" (ephemeral, resets on restart).
STORE_BACKEND=sqlite
SQLITE_PATH=data/clera.db

# --- Metering (informational only; no prepaid balance in the MVP) ---
# Multiplier applied on top of raw provider token cost, shown per draft.
COST_MARKUP=2.5
