# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# --- Telegram ---
# Single-bot dev mode (python -m app.main): an ordinary token from @BotFather.
# Platform mode (python -m app.platform): the MANAGER bot's token — Bot
# Management Mode must be enabled for it in BotFather; per-client secretary
# tokens then come from getManagedBotToken automatically.
TELEGRAM_BOT_TOKEN=123456:PLACEHOLDER_TOKEN_FROM_BOTFATHER

# Single-bot dev override: your numeric Telegram id, where escalations and the
# auto-reply activity feed go. Message @userinfobot to find yours. Leave blank
# (always, in platform mode) to use each connection owner's own chat.
CONTROL_CHAT_ID=

# Echo every auto-sent reply to the control chat (visibility without approval).
NOTIFY_AUTO_REPLIES=true

# Record everything, act on nothing, no LLM calls — the memory-building phase.
# Run with this for a few days, then `python -m app.backfill`, then disable.
COLLECT_ONLY=false

# Hour (local, 0-23) for the daily activity digest; -1 disables the schedule.
DIGEST_HOUR=21

# Never answer messages older than this many seconds (offline backlog guard).
STALE_AFTER_SECONDS=300

# mlx-whisper model for local voice transcription (Apple Silicon).
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# --- LLM providers ---
# "auto" (default): use ANTHROPIC_API_KEY if set, else the local `claude` CLI if
# installed, else a placeholder draft. Force a backend with "anthropic" or "cli".
LLM_PROVIDER=auto
# Path to the Claude CLI (used when LLM_PROVIDER=cli or auto with no API key).
CLAUDE_CLI_PATH=claude
# Only needed for the API backend; leave blank to use the CLI or placeholder.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=              # reserved for the second provider

# --- Model tiers (override defaults if you like) ---
MODEL_BEST=claude-opus-4-8
MODEL_FAST=claude-haiku-4-5-20251001
DEFAULT_TIER=fast              # "best" or "fast"

# --- Storage ---
# "sqlite" (persists to SQLITE_PATH) or "memory" (ephemeral, resets on restart).
STORE_BACKEND=sqlite
SQLITE_PATH=data/clera.db

# --- Metering (informational only; no prepaid balance in the MVP) ---
# Multiplier applied on top of raw provider token cost, shown per draft.
COST_MARKUP=2.5
